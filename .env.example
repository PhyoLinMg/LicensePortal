# Postgres credentials (docker-compose constructs DATABASE_URL from these)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=license_server

# For local dev outside docker, set DATABASE_URL directly (points to localhost)
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/license_server"

# 32-byte AES-256 key for encrypting private keys at rest (base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KEK_BASE64="CHANGE_ME_generate_32_random_bytes_base64"

# JWT signing secret for admin sessions
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="CHANGE_ME_generate_64_random_bytes_base64"

# Admin credentials (bcrypt hash of password)
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD_HASH="$2b$12$CHANGE_ME_bcrypt_hash_of_your_password"

# Public base URL (used in heartbeat URL default)
NEXT_PUBLIC_BASE_URL="https://license.yourcompany.com"

# Optional: upstream URL to reverse-proxy via /api/proxy/* with license gate enforcement.
# Leave unset to disable the proxy feature entirely.
PROXY_UPSTREAM_URL="http://backend:8080"

# Optional: comma-separated path prefixes that bypass the license gate (default: none)
# PROXY_BYPASS_PREFIXES="api/health/,api/webhooks/"
